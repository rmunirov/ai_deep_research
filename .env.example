# ── LLM Provider ──────────────────────────────────────────────────
# Pick one provider and set its API key.
# Variables without DR_ prefix are read directly by LangChain / OpenAI SDK.

# OpenAI / OpenAI-compatible (e.g. local proxy, LM Studio, Ollama)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=http://localhost:8090

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google
# GOOGLE_API_KEY=...

# ── Deep Research Agent settings (DR_ prefix) ────────────────────
# Model in "provider:model" format (langchain init_chat_model)
DR_DEFAULT_MODEL=openai:gpt-4.1

# Optional per-stage model overrides (defaults to DR_DEFAULT_MODEL)
# DR_PLANNER_MODEL=openai:gpt-4.1-mini
# DR_SEARCHER_MODEL=openai:gpt-4.1-mini
# DR_NOTE_TAKER_MODEL=openai:gpt-4.1-mini
# DR_ANALYST_MODEL=openai:gpt-4.1
# DR_WRITER_MODEL=openai:gpt-4.1
# DR_REVIEWER_MODEL=openai:gpt-4.1

# Custom OpenAI-compatible base URL (for local models)
# DR_OPENAI_BASE_URL=http://localhost:8090

# ── Web Search ────────────────────────────────────────────────────
DR_TAVILY_API_KEY=tvly-...
DR_MAX_SEARCH_RESULTS=10

# ── Database ──────────────────────────────────────────────────────
DR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/deep_research

# ── Paths ─────────────────────────────────────────────────────────
DR_RESEARCHES_DIR=./researches

# ── API Server ────────────────────────────────────────────────────
DR_API_HOST=127.0.0.1
DR_API_PORT=8000

# ── Research ──────────────────────────────────────────────────────
DR_LANGUAGE=ru

# ── LangSmith observability (optional) ───────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=deep-research
